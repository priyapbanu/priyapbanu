---
// Contact Section
---

<section id="contact" style="padding:6rem 1.5rem;">
  <div style="max-width:900px;margin:0 auto;">
    <!-- Section header -->
    <div class="reveal" style="text-align:center;margin-bottom:3rem;">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:#38bdf8;font-weight:700;margin-bottom:0.5rem;">// Contact</p>
      <h2 class="section-title" style="color:white;">
        Let's <span class="gradient-text">Connect</span>
      </h2>
      <p style="color:rgba(100,116,139,0.8);font-size:1rem;max-width:500px;margin:0.5rem auto 0;line-height:1.65;">
        Whether you have an exciting DevOps challenge or just want to talk cloud architecture — my inbox is always open.
      </p>
      <div class="glow-divider" style="max-width:100px;margin:1rem auto;"></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.5fr;gap:2.5rem;align-items:start;" class="contact-grid">
      <!-- Contact info -->
      <div class="reveal">
        <div class="glass-card" style="padding:2rem;">
          <h3 style="font-size:1rem;font-weight:700;color:white;margin-bottom:1.5rem;">Get In Touch</h3>

          <!-- Email -->
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;padding:1rem;background:rgba(21,29,53,0.6);border-radius:10px;border:1px solid rgba(30,45,74,0.5);">
            <div style="width:36px;height:36px;background:rgba(56,189,248,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p style="font-size:0.7rem;color:rgba(100,116,139,0.7);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:0.1rem;">Email</p>
              <a href="mailto:priyapbanu2@gmail.com" style="color:rgba(226,232,240,0.9);font-size:0.87rem;text-decoration:none;font-weight:500;">priyapbanu2@gmail.com</a>
            </div>
          </div>

          <!-- Social links -->
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/banu-priyaa/"
              target="_blank"
              rel="noopener noreferrer"
              style="display:flex;align-items:center;gap:0.75rem;padding:1rem;background:rgba(21,29,53,0.6);border-radius:10px;border:1px solid rgba(30,45,74,0.5);text-decoration:none;transition:all 0.2s ease;"
              class="social-link"
            >
              <div style="width:36px;height:36px;background:rgba(10,102,194,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#0a66c2">
                  <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </div>
              <div>
                <p style="font-size:0.7rem;color:rgba(100,116,139,0.7);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:0.1rem;">LinkedIn</p>
                <span style="color:rgba(226,232,240,0.9);font-size:0.87rem;font-weight:500;">linkedin.com/in/banu-priyaa</span>
              </div>
              <svg style="margin-left:auto;color:rgba(100,116,139,0.5);" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
              </svg>
            </a>

            <!-- GitHub -->
            <a
              href="https://github.com/priyapbanu"
              target="_blank"
              rel="noopener noreferrer"
              style="display:flex;align-items:center;gap:0.75rem;padding:1rem;background:rgba(21,29,53,0.6);border-radius:10px;border:1px solid rgba(30,45,74,0.5);text-decoration:none;transition:all 0.2s ease;"
              class="social-link"
            >
              <div style="width:36px;height:36px;background:rgba(255,255,255,0.05);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="white">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </div>
              <div>
                <p style="font-size:0.7rem;color:rgba(100,116,139,0.7);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:0.1rem;">GitHub</p>
                <span style="color:rgba(226,232,240,0.9);font-size:0.87rem;font-weight:500;">github.com/priyapbanu</span>
              </div>
              <svg style="margin-left:auto;color:rgba(100,116,139,0.5);" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div class="reveal">
        <form
          id="contact-form"
          class="glass-card"
          style="padding:2rem;"
          onsubmit="handleFormSubmit(event)"
        >
          <h3 style="font-size:1rem;font-weight:700;color:white;margin-bottom:1.5rem;">Send a Message</h3>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;" class="form-row">
            <div>
              <label for="name" style="display:block;font-size:0.78rem;font-weight:600;color:rgba(148,163,184,0.7);margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.06em;">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your Name"
                style="width:100%;padding:0.7rem 1rem;background:rgba(21,29,53,0.8);border:1px solid rgba(30,45,74,0.8);border-radius:8px;color:white;font-size:0.9rem;outline:none;transition:border-color 0.2s;font-family:inherit;"
                class="form-input"
              />
            </div>
            <div>
              <label for="email" style="display:block;font-size:0.78rem;font-weight:600;color:rgba(148,163,184,0.7);margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.06em;">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                style="width:100%;padding:0.7rem 1rem;background:rgba(21,29,53,0.8);border:1px solid rgba(30,45,74,0.8);border-radius:8px;color:white;font-size:0.9rem;outline:none;transition:border-color 0.2s;font-family:inherit;"
                class="form-input"
              />
            </div>
          </div>

          <div style="margin-bottom:1rem;">
            <label for="subject" style="display:block;font-size:0.78rem;font-weight:600;color:rgba(148,163,184,0.7);margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.06em;">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              placeholder="Project inquiry, collaboration..."
              style="width:100%;padding:0.7rem 1rem;background:rgba(21,29,53,0.8);border:1px solid rgba(30,45,74,0.8);border-radius:8px;color:white;font-size:0.9rem;outline:none;transition:border-color 0.2s;font-family:inherit;"
              class="form-input"
            />
          </div>

          <div style="margin-bottom:1.5rem;">
            <label for="message" style="display:block;font-size:0.78rem;font-weight:600;color:rgba(148,163,184,0.7);margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.06em;">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="Tell me about your project or challenge..."
              style="width:100%;padding:0.7rem 1rem;background:rgba(21,29,53,0.8);border:1px solid rgba(30,45,74,0.8);border-radius:8px;color:white;font-size:0.9rem;outline:none;transition:border-color 0.2s;resize:vertical;font-family:inherit;min-height:120px;"
              class="form-input"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary" style="width:100%;justify-content:center;" id="submit-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            Send Message
          </button>

          <div id="form-success" style="display:none;margin-top:1rem;padding:0.75rem 1rem;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.3);border-radius:8px;color:#34d399;font-size:0.875rem;text-align:center;">
            ✅ Message sent! I'll get back to you soon.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .form-input:focus {
    border-color: rgba(56, 189, 248, 0.5) !important;
    box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.08) !important;
  }
  .form-input::placeholder { color: rgba(100, 116, 139, 0.5); }
  .social-link:hover {
    border-color: rgba(56, 189, 248, 0.3) !important;
    background: rgba(56, 189, 248, 0.05) !important;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr !important; }
    .form-row { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  function handleFormSubmit(event: Event) {
    event.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const success = document.getElementById('form-success');
    btn.disabled = true;
    btn.textContent = 'Sending...';
    // Simulate form submission (replace with Formspree/Netlify Forms in production)
    setTimeout(() => {
      if (success) success.style.display = 'block';
      btn.style.display = 'none';
      (event.target as HTMLFormElement).reset();
    }, 1000);
  }
  (window as any).handleFormSubmit = handleFormSubmit;
</script>
