---
const projects = [
  {
    slug: 'aws-3-tier-architecture',
    title: 'AWS 3-Tier Architecture',
    subtitle: 'with Terraform',
    description: 'Production-ready 3-tier web application architecture on AWS using Terraform. Complete with VPC, ALB, Auto Scaling Groups, RDS Multi-AZ, and CloudFront CDN — all managed as code.',
    tags: ['AWS', 'Terraform', 'VPC', 'RDS', 'ALB', 'Auto Scaling'],
    color: '#FF9900',
    colorBg: 'rgba(255,153,0,0.06)',
    colorBorder: 'rgba(255,153,0,0.2)',
    icon: '☁️',
    github: 'https://github.com/priyapbanu/aws-3tier-terraform',
    featured: true,
  },
  {
    slug: 'kubernetes-production-cluster',
    title: 'Kubernetes Production Cluster',
    subtitle: 'Enterprise Setup',
    description: 'End-to-end production Kubernetes cluster setup on AWS EKS with custom node groups, Cluster Autoscaler, RBAC policies, Ingress controller, cert-manager, and GitOps deployment pipeline.',
    tags: ['Kubernetes', 'EKS', 'Helm', 'ArgoCD', 'Prometheus', 'RBAC'],
    color: '#326CE5',
    colorBg: 'rgba(50,108,229,0.06)',
    colorBorder: 'rgba(50,108,229,0.2)',
    icon: '⚓',
    github: 'https://github.com/priyapbanu/k8s-production-cluster',
    featured: true,
  },
  {
    slug: 'cicd-pipeline-automation',
    title: 'CI/CD Pipeline Automation',
    subtitle: 'GitLab CI',
    description: 'Full-featured GitLab CI/CD pipeline with multi-stage builds, Docker image optimization, automated testing, security scanning (SAST/DAST), and zero-downtime blue/green deployments.',
    tags: ['GitLab CI', 'Docker', 'SAST', 'Blue-Green', 'SonarQube'],
    color: '#FC6D26',
    colorBg: 'rgba(252,109,38,0.06)',
    colorBorder: 'rgba(252,109,38,0.2)',
    icon: '⚙️',
    github: 'https://github.com/priyapbanu/cicd-pipeline-automation',
    featured: false,
  },
  {
    slug: 'elk-centralized-logging',
    title: 'Centralized Logging',
    subtitle: 'ELK Stack',
    description: 'Centralized log aggregation platform using Elasticsearch, Logstash, and Kibana. Collects logs from microservices, Kubernetes pods, and infrastructure — with custom dashboards and alerting.',
    tags: ['Elasticsearch', 'Logstash', 'Kibana', 'Filebeat', 'Kubernetes'],
    color: '#00bfb3',
    colorBg: 'rgba(0,191,179,0.06)',
    colorBorder: 'rgba(0,191,179,0.2)',
    icon: '📊',
    github: 'https://github.com/priyapbanu/elk-centralized-logging',
    featured: false,
  },
];
---

<section id="projects" style="padding:6rem 1.5rem;position:relative;">
  <div style="position:absolute;right:0;top:30%;width:500px;height:500px;background:radial-gradient(ellipse at center, rgba(56,189,248,0.04) 0%, transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;position:relative;">
    <!-- Section header -->
    <div class="reveal" style="margin-bottom:3rem;">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:#34d399;font-weight:700;margin-bottom:0.5rem;">// Projects</p>
      <h2 class="section-title" style="color:white;">
        Production <span style="background:linear-gradient(135deg,#34d399,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Projects</span>
      </h2>
      <p class="section-subtitle">Real-world infrastructure and DevOps projects I've built and documented.</p>
      <div class="glow-divider" style="max-width:100px;margin:1rem 0;"></div>
    </div>

    <!-- Projects grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(520px,1fr));gap:1.5rem;" class="projects-grid">
      {projects.map((project, idx) => (
        <div
          class="glass-card reveal"
          style={`padding:2rem;animation-delay:${idx * 100}ms;border-color:${project.colorBorder};background:${project.colorBg};position:relative;overflow:hidden;`}
        >
          {project.featured && (
            <div style="position:absolute;top:1rem;right:1rem;">
              <span style="display:inline-flex;align-items:center;gap:0.3rem;padding:0.2rem 0.6rem;background:rgba(52,211,153,0.15);border:1px solid rgba(52,211,153,0.3);border-radius:100px;font-size:0.7rem;font-weight:700;color:#34d399;letter-spacing:0.05em;text-transform:uppercase;">
                ⭐ Featured
              </span>
            </div>
          )}

          <!-- Header -->
          <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.25rem;">
            <div style={`width:50px;height:50px;background:${project.colorBg};border:1px solid ${project.colorBorder};border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;`}>
              {project.icon}
            </div>
            <div>
              <h3 style="font-size:1.15rem;font-weight:700;color:white;margin-bottom:0.2rem;">{project.title}</h3>
              <p style={`font-size:0.8rem;font-weight:600;color:${project.color};text-transform:uppercase;letter-spacing:0.06em;`}>{project.subtitle}</p>
            </div>
          </div>

          <p style="color:rgba(148,163,184,0.85);font-size:0.9rem;line-height:1.7;margin-bottom:1.5rem;">{project.description}</p>

          <!-- Tags -->
          <div style="display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:1.5rem;">
            {project.tags.map(tag => (
              <span style={`display:inline-flex;align-items:center;padding:0.2rem 0.6rem;background:rgba(30,45,74,0.6);border:1px solid rgba(30,45,74,0.8);border-radius:4px;font-size:0.72rem;font-weight:500;color:rgba(148,163,184,0.8);font-family:'JetBrains Mono',monospace;`}>
                {tag}
              </span>
            ))}
          </div>

          <!-- Action links -->
          <div style="display:flex;gap:0.75rem;">
            <a
              href={`/projects/${project.slug}`}
              style={`display:inline-flex;align-items:center;gap:0.4rem;padding:0.55rem 1.1rem;background:${project.color}22;border:1px solid ${project.colorBorder};border-radius:7px;font-size:0.82rem;font-weight:600;color:${project.color};text-decoration:none;transition:all 0.2s ease;`}
              class="project-link"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M9 18l6-6-6-6"/>
              </svg>
              View Details
            </a>
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.55rem 1.1rem;background:rgba(30,45,74,0.5);border:1px solid rgba(30,45,74,0.8);border-radius:7px;font-size:0.82rem;font-weight:600;color:rgba(148,163,184,0.8);text-decoration:none;transition:all 0.2s ease;"
              class="github-link"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- View all link -->
    <div class="reveal" style="text-align:center;margin-top:2.5rem;">
      <a href="https://github.com/priyapbanu" target="_blank" rel="noopener noreferrer" class="btn-secondary">
        View All Projects on GitHub →
      </a>
    </div>
  </div>
</section>

<style>
  .project-link:hover { opacity: 0.85; transform: translateY(-1px); }
  .github-link:hover { color: white !important; border-color: rgba(56,189,248,0.3) !important; }
  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 1100px) {
    .projects-grid { grid-template-columns: 1fr !important; }
  }
</style>
