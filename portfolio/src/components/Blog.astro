---
const { posts } = Astro.props;
const allTags = [...new Set(posts.flatMap((p: any) => p.data.tags || []))];
---

<section id="blog" style="padding:6rem 1.5rem;position:relative;">
  <div style="position:absolute;left:0;right:0;bottom:0;height:300px;background:radial-gradient(ellipse at 50% 100%, rgba(129,140,248,0.04) 0%, transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;position:relative;">
    <!-- Section header -->
    <div class="reveal" style="margin-bottom:2rem;">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:#818cf8;font-weight:700;margin-bottom:0.5rem;">// Blog</p>
      <h2 class="section-title" style="color:white;">
        DevOps <span style="background:linear-gradient(135deg,#818cf8,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Insights</span>
      </h2>
      <p class="section-subtitle">Technical deep-dives, tutorials, and best practices from the trenches of DevOps.</p>
      <div class="glow-divider" style="max-width:100px;margin:1rem 0;"></div>
    </div>

    <!-- Tag filters -->
    <div class="reveal" style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:2.5rem;" id="tag-filters">
      <button class="tag active" data-tag="all" onclick="filterPosts('all')">All</button>
      {allTags.map((tag: string) => (
        <button class="tag" data-tag={tag} onclick={`filterPosts('${tag}')`}>{tag}</button>
      ))}
    </div>

    <!-- Blog grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.5rem;" id="blog-grid" class="blog-grid">
      {posts.map((post: any, idx: number) => (
        <article
          class="glass-card reveal blog-post"
          data-tags={JSON.stringify(post.data.tags || [])}
          style={`animation-delay:${idx * 80}ms;overflow:hidden;`}
        >
          <!-- Top accent line -->
          <div style="height:3px;background:linear-gradient(90deg,#818cf8,#38bdf8);margin:-0;border-radius:16px 16px 0 0;"></div>

          <div style="padding:1.75rem;">
            <!-- Meta -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
              <time style="font-size:0.75rem;color:rgba(100,116,139,0.7);font-family:'JetBrains Mono',monospace;">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <span style="font-size:0.72rem;color:rgba(100,116,139,0.6);">
                {post.data.readTime || '5 min read'}
              </span>
            </div>

            <h3 style="font-size:1.1rem;font-weight:700;color:white;margin-bottom:0.6rem;line-height:1.4;">
              <a href={`/blog/${post.slug}`} style="text-decoration:none;color:inherit;transition:color 0.2s;" class="post-title-link">
                {post.data.title}
              </a>
            </h3>

            <p style="color:rgba(100,116,139,0.8);font-size:0.875rem;line-height:1.65;margin-bottom:1.25rem;">{post.data.description}</p>

            <!-- Tags -->
            <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-bottom:1.25rem;">
              {(post.data.tags || []).map((tag: string) => (
                <span style="display:inline-flex;padding:0.15rem 0.55rem;background:rgba(129,140,248,0.1);border:1px solid rgba(129,140,248,0.2);border-radius:4px;font-size:0.7rem;font-weight:600;color:#818cf8;text-transform:uppercase;letter-spacing:0.04em;">
                  {tag}
                </span>
              ))}
            </div>

            <a
              href={`/blog/${post.slug}`}
              style="display:inline-flex;align-items:center;gap:0.35rem;font-size:0.82rem;font-weight:600;color:#818cf8;text-decoration:none;transition:gap 0.2s ease;"
              class="read-more-link"
            >
              Read Article
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- View all -->
    <div class="reveal" style="text-align:center;margin-top:2.5rem;">
      <a href="/blog" class="btn-secondary">View All Articles →</a>
    </div>
  </div>
</section>

<style>
  .post-title-link:hover { color: #818cf8 !important; }
  .read-more-link:hover { gap: 0.6rem !important; }
  .blog-post[data-hidden="true"] { display: none !important; }
  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  function filterPosts(tag: string) {
    const posts = document.querySelectorAll('.blog-post');
    const btns = document.querySelectorAll('[data-tag]');

    btns.forEach(btn => btn.classList.remove('active'));
    document.querySelector(`[data-tag="${tag}"]`)?.classList.add('active');

    posts.forEach(post => {
      const postEl = post as HTMLElement;
      if (tag === 'all') {
        postEl.dataset.hidden = 'false';
      } else {
        const tags = JSON.parse(postEl.dataset.tags || '[]');
        postEl.dataset.hidden = tags.includes(tag) ? 'false' : 'true';
      }
    });
  }

  (window as any).filterPosts = filterPosts;
</script>
