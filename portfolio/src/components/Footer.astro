---
// Footer Component
const year = new Date().getFullYear();
---

<footer style="border-top:1px solid rgba(30,45,74,0.5);padding:2.5rem 1.5rem;">
  <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
    <!-- Logo + copyright -->
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <div style="width:30px;height:30px;background:linear-gradient(135deg,#38bdf8,#818cf8);border-radius:6px;display:flex;align-items:center;justify-content:center;font-weight:900;color:#0a0e1a;font-size:0.75rem;">BP</div>
      <p style="color:rgba(100,116,139,0.7);font-size:0.82rem;">
        © {year} <strong style="color:rgba(148,163,184,0.8);">Banu Priya</strong>. Crafted with ☁️ &amp; ⚙️
      </p>
    </div>

    <!-- Links -->
    <div style="display:flex;align-items:center;gap:1.5rem;">
      <a href="#hero" style="font-size:0.8rem;color:rgba(100,116,139,0.6);text-decoration:none;transition:color 0.2s;" class="footer-link">Back to Top ↑</a>
      <a href="https://github.com/priyapbanu" target="_blank" rel="noopener noreferrer" style="color:rgba(100,116,139,0.6);transition:color 0.2s;" class="footer-link" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a href="https://linkedin.com/in/banupriya" target="_blank" rel="noopener noreferrer" style="color:rgba(100,116,139,0.6);transition:color 0.2s;" class="footer-link" aria-label="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover { color: rgba(226,232,240,0.8) !important; }
</style>
