---
// Hero Section Component
const techStack = ['AWS', 'Kubernetes', 'Terraform', 'Docker', 'GitLab CI', 'Python'];
---

<section
  id="hero"
  style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6rem 1.5rem 4rem;text-align:center;position:relative;overflow:hidden;"
  class="grid-pattern"
>
  <!-- Grid overlay fade -->
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%, transparent 30%, #0a0e1a 100%);pointer-events:none;z-index:1;"></div>

  <div style="position:relative;z-index:2;max-width:900px;margin:0 auto;">
    <!-- Status badge -->
    <div class="animate-fade-up" style="margin-bottom:1.5rem;">
      <span style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.4rem 1rem;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.25);border-radius:100px;font-size:0.78rem;font-weight:600;color:#34d399;letter-spacing:0.05em;text-transform:uppercase;">
        <span style="width:6px;height:6px;background:#34d399;border-radius:50%;display:inline-block;animation:pulse 2s ease-in-out infinite;"></span>
        Available for opportunities
      </span>
    </div>

    <!-- Name -->
    <h1 class="animate-fade-up delay-100" style="font-size:clamp(2.5rem,8vw,5rem);font-weight:900;letter-spacing:-0.04em;line-height:1;margin-bottom:1rem;">
      <span style="color:white;">Hi, I'm </span>
      <span class="gradient-text">Banu Priya</span>
    </h1>

    <!-- Title -->
    <p class="animate-fade-up delay-200" style="font-size:clamp(1rem,3vw,1.4rem);font-weight:500;color:rgba(148,163,184,0.9);margin-bottom:1.5rem;letter-spacing:-0.01em;">
      DevOps Engineer &bull; <span style="color:#38bdf8;">AWS</span> &bull; <span style="color:#818cf8;">Kubernetes</span> &bull; <span style="color:#34d399;">Terraform</span> &bull; CI/CD
    </p>

    <!-- Description -->
    <p class="animate-fade-up delay-300" style="font-size:1.05rem;color:rgba(100,116,139,0.9);max-width:600px;margin:0 auto 2.5rem;line-height:1.7;">
      Building scalable cloud infrastructure, automating everything, and bridging the gap between development and operations. I turn complex systems into reliable, observable, and effortlessly deployable platforms.
    </p>

    <!-- CTA Buttons -->
    <div class="animate-fade-up delay-400" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem;">
      <a href="#projects" class="btn-primary animate-pulse-glow">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 01.84 7.81 19.79 19.79 0 113.19 2.18a2 2 0 012 1.72l.83 4.5"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        View Projects
      </a>
      <a href="/Banu_DevOps.pdf" download class="btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download Resume
      </a>
      <a
        href="https://github.com/priyapbanu"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>

    <!-- Tech stack pills -->
    <div class="animate-fade-up delay-500">
      <p style="font-size:0.75rem;color:rgba(100,116,139,0.7);margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.1em;font-weight:600;">Core Stack</p>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;justify-content:center;">
        {techStack.map((tech, i) => (
          <span
            class="skill-badge"
            style={`animation-delay:${i * 80}ms;`}
          >
            {tech}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="animate-float"
    style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:0.4rem;color:rgba(100,116,139,0.5);"
    aria-hidden="true"
  >
    <span style="font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;">Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
</style>
