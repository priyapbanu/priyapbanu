---
const skillCategories = [
  {
    title: 'Cloud Platforms',
    icon: '☁️',
    color: '#FF9900',
    colorBg: 'rgba(255,153,0,0.08)',
    colorBorder: 'rgba(255,153,0,0.2)',
    skills: [
      { name: 'Amazon Web Services', abbr: 'AWS', level: 95 },
      { name: 'Google Cloud Platform', abbr: 'GCP', level: 75 },
    ],
  },
  {
    title: 'Containers & Orchestration',
    icon: '🐳',
    color: '#2496ED',
    colorBg: 'rgba(36,150,237,0.08)',
    colorBorder: 'rgba(36,150,237,0.2)',
    skills: [
      { name: 'Docker', abbr: 'Docker', level: 95 },
      { name: 'Kubernetes', abbr: 'K8s', level: 90 },
      { name: 'Helm Charts', abbr: 'Helm', level: 80 },
    ],
  },
  {
    title: 'Infrastructure as Code',
    icon: '🏗️',
    color: '#7B42F5',
    colorBg: 'rgba(123,66,245,0.08)',
    colorBorder: 'rgba(123,66,245,0.2)',
    skills: [
      { name: 'Terraform', abbr: 'TF', level: 92 },
      { name: 'Ansible', abbr: 'Ansible', level: 75 },
      { name: 'CloudFormation', abbr: 'CFN', level: 70 },
    ],
  },
  {
    title: 'CI/CD & Automation',
    icon: '⚙️',
    color: '#FC6D26',
    colorBg: 'rgba(252,109,38,0.08)',
    colorBorder: 'rgba(252,109,38,0.2)',
    skills: [
      { name: 'GitLab CI/CD', abbr: 'GitLab', level: 90 },
      { name: 'GitHub Actions', abbr: 'GH Actions', level: 85 },
      { name: 'Jenkins', abbr: 'Jenkins', level: 70 },
    ],
  },
  {
    title: 'Monitoring & Observability',
    icon: '📊',
    color: '#E6522C',
    colorBg: 'rgba(230,82,44,0.08)',
    colorBorder: 'rgba(230,82,44,0.2)',
    skills: [
      { name: 'Prometheus', abbr: 'Prometheus', level: 88 },
      { name: 'Grafana', abbr: 'Grafana', level: 85 },
      { name: 'ELK Stack', abbr: 'ELK', level: 82 },
    ],
  },
  {
    title: 'Languages & Scripting',
    icon: '💻',
    color: '#34d399',
    colorBg: 'rgba(52,211,153,0.08)',
    colorBorder: 'rgba(52,211,153,0.2)',
    skills: [
      { name: 'Python', abbr: 'Python', level: 88 },
      { name: 'Bash / Shell', abbr: 'Bash', level: 90 },
      { name: 'Java', abbr: 'Java', level: 70 },
    ],
  },
];
---

<section id="skills" style="padding:6rem 1.5rem;position:relative;">
  <!-- Background accent -->
  <div style="position:absolute;left:0;right:0;top:50%;transform:translateY(-50%);height:300px;background:radial-gradient(ellipse at 20% 50%, rgba(129,140,248,0.04) 0%, transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;position:relative;">
    <!-- Section header -->
    <div class="reveal" style="margin-bottom:3rem;">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:#818cf8;font-weight:700;margin-bottom:0.5rem;">// Technical Skills</p>
      <h2 class="section-title" style="color:white;">
        My <span style="background:linear-gradient(135deg,#818cf8,#34d399);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Toolkit</span>
      </h2>
      <p class="section-subtitle">Battle-tested tools and technologies I use to build, deploy, and operate production systems.</p>
      <div class="glow-divider" style="max-width:100px;margin:1rem 0;"></div>
    </div>

    <!-- Skills grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.5rem;" class="skills-grid">
      {skillCategories.map((category, idx) => (
        <div
          class="glass-card reveal"
          style={`padding:1.75rem;animation-delay:${idx * 80}ms;border-color:${category.colorBorder};`}
        >
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
            <div style={`width:42px;height:42px;background:${category.colorBg};border:1px solid ${category.colorBorder};border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.25rem;`}>
              {category.icon}
            </div>
            <h3 style={`font-size:1rem;font-weight:700;color:${category.color};`}>{category.title}</h3>
          </div>

          <div style="display:flex;flex-direction:column;gap:1rem;">
            {category.skills.map(skill => (
              <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:0.4rem;">
                  <span style="font-size:0.875rem;font-weight:500;color:rgba(226,232,240,0.9);">{skill.name}</span>
                  <span style={`font-size:0.75rem;font-weight:700;color:${category.color};`}>{skill.level}%</span>
                </div>
                <div style="height:4px;background:rgba(30,45,74,0.8);border-radius:100px;overflow:hidden;">
                  <div
                    class="skill-bar"
                    style={`height:100%;width:${skill.level}%;background:linear-gradient(90deg,${category.color}99,${category.color});border-radius:100px;transition:width 1.2s ease;`}
                    data-width={skill.level}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications row -->
    <div class="reveal" style="margin-top:3rem;padding:2rem;background:rgba(15,22,41,0.6);border:1px solid rgba(30,45,74,0.8);border-radius:16px;">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(100,116,139,0.7);font-weight:600;text-align:center;margin-bottom:1.25rem;">Certifications & Recognition</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
        {['AWS Solutions Architect', 'AWS DevOps Engineer', 'Certified Kubernetes Admin', 'Terraform Associate', 'GCP Associate CE'].map(cert => (
          <span class="tag">🏆 {cert}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    .skills-grid { grid-template-columns: 1fr !important; }
  }
</style>
