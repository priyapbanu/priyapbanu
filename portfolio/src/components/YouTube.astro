---
const videos = [
  {
    id: 'dQw4w9WgXcQ', // Replace with actual YouTube video IDs
    title: 'Building AWS 3-Tier Architecture with Terraform',
    description: 'Step-by-step guide to deploying a production-ready 3-tier architecture on AWS from scratch using Terraform modules.',
    tags: ['AWS', 'Terraform', 'IaC'],
    duration: '45:23',
  },
  {
    id: 'X48VuDVv0do',
    title: 'Kubernetes Production Cluster Setup from Scratch',
    description: 'Complete walkthrough of setting up EKS, configuring RBAC, Ingress, cert-manager, and GitOps with ArgoCD.',
    tags: ['Kubernetes', 'EKS', 'GitOps'],
    duration: '1:12:05',
  },
  {
    id: 'i32KDxkBFII',
    title: 'GitLab CI/CD Pipeline: Zero to Hero',
    description: 'Build a production-grade GitLab CI/CD pipeline with multi-stage deployments, Docker builds, and security scanning.',
    tags: ['CI/CD', 'GitLab', 'Docker'],
    duration: '38:47',
  },
  {
    id: 'h0Lztjf2xhY',
    title: 'ELK Stack: Centralized Logging for Microservices',
    description: 'Deploy and configure the full ELK stack for centralized log aggregation from Kubernetes microservices at scale.',
    tags: ['ELK', 'Monitoring', 'Kubernetes'],
    duration: '52:10',
  },
];
---

<section id="youtube" style="padding:6rem 1.5rem;position:relative;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%, rgba(255,0,0,0.03) 0%, transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;position:relative;">
    <!-- Section header -->
    <div class="reveal" style="margin-bottom:3rem;">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:#ef4444;font-weight:700;margin-bottom:0.5rem;">// YouTube</p>
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <h2 class="section-title" style="color:white;">
            DevOps <span style="background:linear-gradient(135deg,#ef4444,#f97316);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Tutorials</span>
          </h2>
          <p class="section-subtitle">Video walkthroughs on cloud infrastructure, DevOps practices, and real-world implementations.</p>
        </div>
        <a
          href="https://youtube.com/@banupriyaDevOps"
          target="_blank"
          rel="noopener noreferrer"
          style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.6rem 1.25rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;font-size:0.85rem;font-weight:600;color:#ef4444;text-decoration:none;transition:all 0.2s ease;white-space:nowrap;"
          class="yt-channel-link"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Subscribe on YouTube
        </a>
      </div>
      <div class="glow-divider" style="max-width:100px;margin:1rem 0;"></div>
    </div>

    <!-- Video grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(520px,1fr));gap:1.5rem;" class="videos-grid">
      {videos.map((video, idx) => (
        <div
          class="glass-card reveal"
          style={`overflow:hidden;animation-delay:${idx * 100}ms;border-color:rgba(239,68,68,0.12);`}
        >
          <!-- Video Embed -->
          <div style="position:relative;width:100%;padding-top:56.25%;background:#0d1117;overflow:hidden;">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"
            ></iframe>
          </div>

          <!-- Info -->
          <div style="padding:1.25rem;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.6rem;">
              <div style="display:flex;gap:0.35rem;flex-wrap:wrap;">
                {video.tags.map(tag => (
                  <span style="display:inline-flex;padding:0.15rem 0.5rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:4px;font-size:0.68rem;font-weight:700;color:#ef4444;text-transform:uppercase;letter-spacing:0.04em;">
                    {tag}
                  </span>
                ))}
              </div>
              <span style="font-size:0.75rem;color:rgba(100,116,139,0.7);font-family:'JetBrains Mono',monospace;">⏱ {video.duration}</span>
            </div>
            <h3 style="font-size:0.95rem;font-weight:700;color:white;margin-bottom:0.4rem;line-height:1.4;">{video.title}</h3>
            <p style="font-size:0.82rem;color:rgba(100,116,139,0.8);line-height:1.55;">{video.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .yt-channel-link:hover { background: rgba(239,68,68,0.18) !important; }
  @media (max-width: 640px) {
    .videos-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 1100px) {
    .videos-grid { grid-template-columns: 1fr !important; }
  }
</style>
