---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Centralized Logging with ELK Stack | Banu Priya" description="Centralized log aggregation platform using Elasticsearch, Logstash, and Kibana for Kubernetes microservices observability.">
  <Navbar />
  <main style="padding-top:80px;min-height:100vh;">
    <div style="padding:4rem 1.5rem 2rem;background:linear-gradient(180deg,rgba(15,22,41,0.9) 0%,transparent 100%);border-bottom:1px solid rgba(30,45,74,0.4);">
      <div style="max-width:900px;margin:0 auto;">
        <a href="/#projects" style="display:inline-flex;align-items:center;gap:0.35rem;font-size:0.82rem;color:rgba(100,116,139,0.7);text-decoration:none;margin-bottom:1.5rem;">← Back to Projects</a>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
          {['Elasticsearch','Logstash','Kibana','Kubernetes'].map(tag => (
            <span style="display:inline-flex;padding:0.2rem 0.7rem;background:rgba(0,191,179,0.12);border:1px solid rgba(0,191,179,0.25);border-radius:4px;font-size:0.72rem;font-weight:700;color:#00bfb3;text-transform:uppercase;letter-spacing:0.06em;">{tag}</span>
          ))}
        </div>
        <h1 style="font-size:clamp(1.75rem,5vw,2.75rem);font-weight:900;color:white;letter-spacing:-0.03em;line-height:1.2;margin-bottom:0.75rem;">Centralized Logging <span style="color:#00bfb3;">with ELK</span></h1>
        <p style="color:rgba(148,163,184,0.85);font-size:1rem;line-height:1.65;margin-bottom:1.5rem;">Enterprise log aggregation platform collecting, parsing, and visualizing logs from Kubernetes pods, infrastructure, and application services at scale.</p>
        <a href="https://github.com/priyapbanu/elk-centralized-logging" target="_blank" rel="noopener noreferrer" class="btn-primary" style="font-size:0.85rem;padding:0.6rem 1.25rem;">View on GitHub</a>
      </div>
    </div>

    <div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem 6rem;" class="prose-devops">
      <h2>Log Flow Architecture</h2>
      <div style="background:#0d1117;border:1px solid rgba(30,45,74,0.8);border-radius:12px;padding:1.5rem;margin-bottom:1.5rem;overflow-x:auto;">
        <pre style="color:#00bfb3;font-family:'JetBrains Mono',monospace;font-size:0.78rem;line-height:1.6;margin:0;">{`
K8s Pods          Infrastructure      Applications
    │                    │                 │
    ▼ (Filebeat DaemonSet)▼ (Metricbeat)   ▼ (Logstash Shipper)
┌───────────────────────────────────────────────┐
│                  Logstash                      │
│  Parse → Filter → Enrich → Transform → Route  │
└────────────────────┬──────────────────────────┘
                     │
          ┌──────────▼──────────┐
          │   Elasticsearch     │
          │   Cluster           │
          │  ┌────┐ ┌────┐      │
          │  │ N1 │ │ N2 │ ...  │  ← 3+ nodes, hot-warm-cold
          │  └────┘ └────┘      │
          └──────────┬──────────┘
                     │
          ┌──────────▼──────────┐
          │      Kibana         │
          │  Dashboards         │
          │  Alerts             │
          │  SIEM               │
          └─────────────────────┘
`}</pre>
      </div>

      <h2>Tech Stack</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.75rem;margin-bottom:2rem;">
        {['Elasticsearch 8.x','Logstash 8.x','Kibana 8.x','Filebeat DaemonSet','Metricbeat','Helm Charts','Kubernetes','ILM Policies','Elastic APM','Watcher Alerts'].map(item => (
          <div style="padding:0.6rem 0.85rem;background:rgba(21,29,53,0.8);border:1px solid rgba(0,191,179,0.2);border-radius:8px;font-size:0.82rem;font-weight:600;color:rgba(226,232,240,0.85);">{item}</div>
        ))}
      </div>

      <h2>Folder Structure</h2>
      <div style="background:#0d1117;border:1px solid rgba(30,45,74,0.8);border-radius:12px;padding:1.5rem;margin-bottom:2rem;overflow-x:auto;">
        <pre style="color:#e2e8f0;font-family:'JetBrains Mono',monospace;font-size:0.8rem;line-height:1.7;margin:0;">{`elk-centralized-logging/
├── helm/
│   ├── elasticsearch/
│   │   ├── values.yaml         # 3-node cluster config
│   │   └── ilm-policy.json     # Index lifecycle policy
│   ├── logstash/
│   │   ├── values.yaml
│   │   └── pipeline/
│   │       ├── k8s-logs.conf
│   │       └── app-logs.conf
│   ├── kibana/
│   │   └── values.yaml
│   └── filebeat/
│       └── values.yaml         # DaemonSet config
├── kibana-dashboards/
│   ├── k8s-overview.ndjson
│   ├── application-logs.ndjson
│   └── infrastructure.ndjson
├── logstash-pipelines/
│   ├── k8s-logs.conf
│   ├── nginx-access.conf
│   └── app-structured.conf
└── terraform/
    └── aws-elasticsearch.tf    # AWS OpenSearch (optional)`}</pre>
      </div>

      <h2>Key Features</h2>
      <ul style="list-style:none;padding:0;">
        {[
          '📊 Kibana dashboards for K8s cluster, pods, and namespaces',
          '🔄 Index Lifecycle Management (hot-warm-cold-delete)',
          '🔍 Full-text search across 10+ microservices',
          '⚠️ Watcher alerts for error rate spikes and anomalies',
          '🏷️ Structured JSON log parsing with Logstash filters',
          '📦 Filebeat DaemonSet for automatic pod log collection',
          '📈 Elastic APM integration for distributed tracing',
          '🔐 Role-based access control for team log namespaces',
        ].map(f => (
          <li style="padding:0.6rem 1rem;margin-bottom:0.5rem;background:rgba(21,29,53,0.5);border:1px solid rgba(0,191,179,0.15);border-radius:8px;font-size:0.875rem;color:rgba(148,163,184,0.85);">{f}</li>
        ))}
      </ul>

      <div style="margin-top:2.5rem;">
        <a href="https://github.com/priyapbanu/elk-centralized-logging" target="_blank" rel="noopener noreferrer" class="btn-primary">View Full Source on GitHub →</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
