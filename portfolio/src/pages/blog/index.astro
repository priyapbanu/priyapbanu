---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const postModules = import.meta.glob('./*.{md,mdx}', { eager: true });
const allPosts = Object.entries(postModules).map(([path, mod]: [string, any]) => ({
  slug: path.split('/').pop()?.replace(/\.(md|mdx)$/, '') || '',
  data: mod.frontmatter,
}));
const posts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
---

<Layout
  title="DevOps Blog | Banu Priya"
  description="Technical deep-dives, tutorials, and DevOps best practices from Banu Priya — covering AWS, Kubernetes, Terraform, CI/CD, and more."
>
  <Navbar />
  <main style="padding-top:80px;min-height:100vh;">
    <!-- Header -->
    <div style="padding:4rem 1.5rem 3rem;text-align:center;border-bottom:1px solid rgba(30,45,74,0.4);">
      <p style="font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:#818cf8;font-weight:700;margin-bottom:0.5rem;">// All Articles</p>
      <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:900;color:white;letter-spacing:-0.03em;margin-bottom:0.75rem;">
        DevOps <span style="background:linear-gradient(135deg,#818cf8,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Blog</span>
      </h1>
      <p style="color:rgba(100,116,139,0.8);font-size:1rem;max-width:500px;margin:0 auto 2rem;">
        Technical deep-dives, tutorials, and best practices from the trenches of DevOps engineering.
      </p>

      <!-- Tag filters -->
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;justify-content:center;" id="tag-filters">
        <button class="tag active" data-tag="all" onclick="filterPosts('all')">All Posts ({posts.length})</button>
        {allTags.map((tag: string) => (
          <button class="tag" data-tag={tag} onclick={`filterPosts('${tag}')`}>{tag}</button>
        ))}
      </div>
    </div>

    <!-- Posts grid -->
    <div style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem 6rem;">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.5rem;" id="blog-grid" class="blog-grid">
        {posts.map((post, idx) => (
          <article
            class="glass-card blog-post reveal"
            data-tags={JSON.stringify(post.data.tags || [])}
            style={`animation-delay:${idx * 60}ms;overflow:hidden;`}
          >
            <div style="height:3px;background:linear-gradient(90deg,#818cf8,#38bdf8);border-radius:16px 16px 0 0;"></div>
            <div style="padding:1.75rem;">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                <time style="font-size:0.75rem;color:rgba(100,116,139,0.7);font-family:'JetBrains Mono',monospace;">
                  {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <span style="font-size:0.72rem;color:rgba(100,116,139,0.6);">
                  {post.data.readTime || '5 min read'}
                </span>
              </div>
              <h2 style="font-size:1.05rem;font-weight:700;color:white;margin-bottom:0.6rem;line-height:1.4;">
                <a href={`/blog/${post.slug}`} style="text-decoration:none;color:inherit;transition:color 0.2s;" class="post-link">{post.data.title}</a>
              </h2>
              <p style="color:rgba(100,116,139,0.8);font-size:0.875rem;line-height:1.65;margin-bottom:1.25rem;">{post.data.description}</p>
              <div style="display:flex;gap:0.35rem;flex-wrap:wrap;margin-bottom:1.25rem;">
                {(post.data.tags || []).map((tag: string) => (
                  <span style="display:inline-flex;padding:0.15rem 0.55rem;background:rgba(129,140,248,0.1);border:1px solid rgba(129,140,248,0.2);border-radius:4px;font-size:0.7rem;font-weight:600;color:#818cf8;text-transform:uppercase;letter-spacing:0.04em;">
                    {tag}
                  </span>
                ))}
              </div>
              <a href={`/blog/${post.slug}`} style="display:inline-flex;align-items:center;gap:0.35rem;font-size:0.82rem;font-weight:600;color:#818cf8;text-decoration:none;" class="read-link">
                Read Article →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .post-link:hover { color: #818cf8 !important; }
  .read-link:hover { gap: 0.55rem !important; }
  .blog-post[data-hidden="true"] { display: none !important; }
  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  function filterPosts(tag: string) {
    const posts = document.querySelectorAll('.blog-post');
    const btns = document.querySelectorAll('[data-tag]');
    btns.forEach(btn => btn.classList.remove('active'));
    document.querySelector(`[data-tag="${tag}"]`)?.classList.add('active');
    posts.forEach(post => {
      const postEl = post as HTMLElement;
      if (tag === 'all') {
        postEl.dataset.hidden = 'false';
      } else {
        const tags = JSON.parse(postEl.dataset.tags || '[]');
        postEl.dataset.hidden = tags.includes(tag) ? 'false' : 'true';
      }
    });
  }
  (window as any).filterPosts = filterPosts;
</script>
