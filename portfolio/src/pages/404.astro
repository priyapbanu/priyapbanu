---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 – Page Not Found | Banu Priya" description="The page you're looking for doesn't exist.">
  <Navbar />
  <main style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;">
    <div style="max-width:500px;">
      <div style="font-size:6rem;font-weight:900;background:linear-gradient(135deg,#38bdf8,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;margin-bottom:1rem;">404</div>
      <h1 style="font-size:1.5rem;font-weight:700;color:white;margin-bottom:0.75rem;">Page Not Found</h1>
      <p style="color:rgba(100,116,139,0.8);font-size:0.95rem;line-height:1.65;margin-bottom:2rem;">
        Looks like this page doesn't exist or was moved. Let's get you back on track.
      </p>
      <a href="/" class="btn-primary">← Back to Home</a>
    </div>
  </main>
  <Footer />
</Layout>
